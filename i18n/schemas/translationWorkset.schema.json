{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Translation Workset",
	"type": "object",
	"additionalProperties": false,
	"required": ["$schema", "version", "locale", "domain", "generatedAt", "entries"],
	"properties": {
		"$schema": { "type": "string" },
		"version": { "const": 2 },
		"locale": { "const": "zh-cn" },
		"domain": { "const": "manifest" },
		"generatedAt": { "type": "string", "format": "date-time" },
		"entries": {
			"type": "array",
			"items": { "$ref": "#/definitions/entry" }
		}
	},
	"definitions": {
		"translationValue": {
			"anyOf": [{ "type": "string" }, { "type": "null" }]
		},
		"caseRecord": {
			"type": "object",
			"additionalProperties": false,
			"required": ["source", "translation"],
			"properties": {
				"source": { "type": "string" },
				"translation": { "$ref": "#/definitions/translationValue" }
			}
		},
		"baseEntry": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "kind", "source", "translation", "sourceHash", "keys", "status"],
			"properties": {
				"id": { "type": "string" },
				"kind": { "enum": ["literal", "template", "select", "plural", "rich"] },
				"source": { "type": "string" },
				"translation": { "$ref": "#/definitions/translationValue" },
				"slots": { "type": "array", "items": { "type": "string" } },
				"selector": { "type": "string" },
				"cases": { "type": "object", "additionalProperties": { "$ref": "#/definitions/caseRecord" } },
				"format": { "const": "markdown" },
				"sourceHash": { "type": "string" },
				"keys": {
					"type": "array",
					"minItems": 1,
					"uniqueItems": true,
					"items": { "type": "string" }
				},
				"status": { "enum": ["pending", "translated", "needsReview", "approved"] },
				"note": { "type": "string" }
			}
		},
		"entry": {
			"anyOf": [
				{
					"allOf": [
						{ "$ref": "#/definitions/baseEntry" },
						{
							"properties": { "kind": { "const": "literal" } }
						}
					]
				},
				{
					"allOf": [
						{ "$ref": "#/definitions/baseEntry" },
						{
							"properties": { "kind": { "const": "template" } },
							"required": ["slots"]
						}
					]
				},
				{
					"allOf": [
						{ "$ref": "#/definitions/baseEntry" },
						{
							"properties": { "kind": { "const": "rich" } },
							"required": ["format", "slots"]
						}
					]
				},
				{
					"allOf": [
						{ "$ref": "#/definitions/baseEntry" },
						{
							"properties": { "kind": { "const": "select" } },
							"required": ["selector", "cases"]
						}
					]
				},
				{
					"allOf": [
						{ "$ref": "#/definitions/baseEntry" },
						{
							"properties": { "kind": { "const": "plural" } },
							"required": ["selector", "cases"]
						}
					]
				}
			]
		}
	}
}
