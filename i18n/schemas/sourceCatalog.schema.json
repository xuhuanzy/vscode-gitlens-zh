{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Source Catalog",
	"type": "object",
	"additionalProperties": false,
	"required": ["$schema", "version", "domain", "generatedAt", "deferredDomains", "occurrences"],
	"properties": {
		"$schema": { "type": "string" },
		"version": { "const": 3 },
		"domain": { "enum": ["manifest", "webviews", "quickpicks", "formatter"] },
		"generatedAt": { "type": "string", "format": "date-time" },
		"deferredDomains": {
			"type": "array",
			"items": { "enum": ["manifest", "webviews", "quickpicks", "formatter"] }
		},
		"occurrences": {
			"type": "array",
			"items": { "$ref": "#/definitions/occurrence" }
		}
	},
	"definitions": {
		"sourceReference": {
			"anyOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["kind", "file", "pointer", "segments"],
					"properties": {
						"kind": { "const": "json" },
						"file": { "type": "string" },
						"pointer": { "type": "string" },
						"segments": {
							"type": "array",
							"items": {
								"anyOf": [{ "type": "string" }, { "type": "integer" }]
							}
						}
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["kind", "file", "syntax", "start", "end"],
					"properties": {
						"kind": { "const": "source" },
						"file": { "type": "string" },
						"syntax": { "type": "string" },
						"start": { "$ref": "#/definitions/position" },
						"end": { "$ref": "#/definitions/position" },
						"attribute": { "type": "string" }
					}
				}
			]
		},
		"position": {
			"type": "object",
			"additionalProperties": false,
			"required": ["line", "column"],
			"properties": {
				"line": { "type": "integer", "minimum": 1 },
				"column": { "type": "integer", "minimum": 1 }
			}
		},
		"outputReference": {
			"anyOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["kind", "key"],
					"properties": {
						"kind": { "const": "manifest-key" },
						"key": { "type": "string" }
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["kind", "bundle", "key"],
					"properties": {
						"kind": { "const": "runtime-key" },
						"bundle": { "type": "string" },
						"key": { "type": "string" }
					}
				}
			]
		},
		"occurrence": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"domain",
				"scope",
				"anchor",
				"slot",
				"authorityId",
				"pattern",
				"sourceText",
				"sourceHash",
				"reference"
			],
			"properties": {
				"id": { "type": "string" },
				"domain": { "enum": ["manifest", "webviews", "quickpicks", "formatter"] },
				"scope": { "type": "string" },
				"anchor": { "type": "string" },
				"slot": { "type": "string" },
				"authorityId": { "type": "string" },
				"pattern": { "$ref": "./messagePattern.schema.json" },
				"sourceText": { "type": "string" },
				"sourceHash": { "type": "string" },
				"reference": { "$ref": "#/definitions/sourceReference" },
				"output": { "$ref": "#/definitions/outputReference" }
			}
		}
	}
}
